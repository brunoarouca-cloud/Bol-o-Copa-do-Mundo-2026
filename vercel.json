{
  "crons": [
    {
      "path": "/api/generate-news",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/live-scores",
      "schedule": "* * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
